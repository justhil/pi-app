{
  "id": "@juicesharp/rpiv-ask-user-question",
  "displayName": "Ask User Question",
  "description": "结构化问卷（桌面问卷对话框，含选项预览合并）",
  "match": {
    "names": ["@juicesharp/rpiv-ask-user-question", "rpiv-ask-user-question"],
    "tools": ["ask_user_question"]
  },
  "tier": "native",
  "toolCard": { "template": "kv", "icon": "MessageCircleQuestion" },
  "interact": {
    "trigger": { "tool": "ask_user_question" },
    "schema": "questions",
    "fields": { "questions": "$.args.questions", "options": "$.args.options" }
  },
  "config": {
    "note": "问卷交互由 Worker 注入 uiContext 并转发 extension-ui-request；桌面 QuestionnaireDialog 渲染，无需配置。"
  }
}
