{
  "id": "pi-intercom",
  "displayName": "Intercom",
  "description": "跨会话协调（工具执行 + 只读 snapshot）",
  "match": {
    "names": ["pi-intercom"],
    "tools": ["intercom", "contact_supervisor"],
    "commands": ["/intercom"]
  },
  "tier": "headless",
  "toolCard": { "template": "default", "icon": "MessagesSquare" },
  "config": {
    "note": "Intercom broker 经 ~/.pi/agent/intercom 命名管道/Unix socket 运行；桌面仅只读配置与 snapshot，工具执行由扩展。"
  },
  "slash": { "/intercom": "notify" }
}
