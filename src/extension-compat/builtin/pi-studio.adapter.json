  "tier": "partial",
  "toolCard": {
    "template": "default",
    "icon": "Terminal"
  },
  "config": {
    "note": "Studio REPL/导出由扩展工具执行；桌面无 tmux 终端，仅结果卡片与打开产物。"
  },
  "slash": {
