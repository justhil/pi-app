    "/studio-replace": "config-page",
    "/studio-editor-only": "config-page",
    "/studio-pdf": "notify",
    "/studio-html": "notify",
    "/studio-current": "notify"
  },
  "i18n": {
    "zh": {
      "displayName": "Studio",
      "description": "REPL 与 PDF/HTML 导出工具（结果卡片 + 打开产物）"
    },
    "en": {
      "displayName": "Studio",
      "description": "REPL and PDF/HTML export tool (screenshot + open file)"
    }
  }
