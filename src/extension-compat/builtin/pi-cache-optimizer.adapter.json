{
  "id": "pi-cache-optimizer",
  "displayName": "Cache Optimizer",
  "description": "缓存优化（运行时开关，影响新会话启动）",
  "match": { "names": ["pi-cache-optimizer"], "commands": ["/cache-optimizer"] },
  "tier": "headless",
  "config": {
    "sections": [
      {
        "title": "优化开关（环境变量）",
        "fields": [
          { "key": "PI_CACHE_OPTIMIZER_NO_OPENAI_CACHE_KEY", "type": "boolean", "label": "禁用 OpenAI cache key 优化", "default": false },
          { "key": "PI_CACHE_OPTIMIZER_NO_SKILL_COMPRESSION", "type": "boolean", "label": "禁用技能压缩", "default": false }
        ]
      }
    ],
    "note": "这些开关对应环境变量，仅在新会话启动时生效（与扩展 /cache-optimizer disable 行为一致）。运行中切换请在终端用 /cache-optimizer。"
  },
  "slash": { "/cache-optimizer": "config-page" }
}
