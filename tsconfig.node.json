{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/worker/**/*",
    "src/extension-compat/**/*",
    "!src/extension-compat/renderer/**/*",
    "packages/shared/**/*",
    "electron.vite.config.ts"
  ]
}
